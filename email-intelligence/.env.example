# ── Ollama ───────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434

# General model for classification, sentiment, urgency, summary agents
# Pull first: ollama pull llama3.2
GENERAL_LLM_MODEL=llama3.2

# Fine-tuned phishing detector (built by this project)
# Deploy first: cd outputs/llama3.2-3b-phishing/saved_models/<run>/
#               ollama create phishing-detector -f Modelfile
THREAT_LLM_MODEL=phishing-detector

# ── Gmail IMAP ───────────────────────────────────────────────────────────────
# 1. Enable IMAP in Gmail → Settings → Forwarding and POP/IMAP → Enable IMAP
# 2. Enable 2-Step Verification on your Google Account
# 3. Google Account → Security → App passwords → create one for Mail
GMAIL_ADDRESS=your@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
GMAIL_POLL_INTERVAL=60

# ── Telegram ─────────────────────────────────────────────────────────────────
# 1. Message @BotFather on Telegram → /newbot → copy the token
# 2. Message @userinfobot on Telegram → /start → copy your Chat ID
# 3. Start a conversation with your bot first (search its username, hit Start)
TELEGRAM_BOT_TOKEN=123456789:ABCdef...
TELEGRAM_CHAT_ID=987654321
# false = only notify on phishing/spam   true = notify on every email
TELEGRAM_NOTIFY_ALL=false

# ── Optional: LangSmith tracing ──────────────────────────────────────────────
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=your_key_here
# LANGCHAIN_PROJECT=email-intelligence